# Host path to the repository mounted read-only into the assistant container.
HOST_REPO_PATH=.

# Container path where the repository is mounted and indexed.
REPO_PATH=/repo

# Optional Ollama model override.
OLLAMA_MODEL=qwen2.5-coder:7b

# Optional VS Code MCP JSON override controls.
VSCODE_MCP_JSON_PATH=/workspace/.vscode/mcp.json
VSCODE_MCP_SERVER_NAME=local-infra-assistant
